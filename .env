# Salin file ini menjadi .env lalu sesuaikan nilainya.

# URL koneksi mysql
# Format: mysql://USER:PASSWORD@HOST:PORT/NAMADATABASE
DATABASE_URL=mysql://mysql:mysql@localhost:5432/presensi_aqua

# Port server backend
PORT=3001

# Asal (origin) frontend yang diizinkan untuk CORS
FRONTEND_ORIGIN=http://localhost:5173

# Kunci rahasia untuk session (boleh diisi string acak panjang)
SESSION_SECRET=ubah-kunci-rahasia-ini-menjadi-string-acak

# Lingkungan: "development" atau "production"
NODE_ENV=development
